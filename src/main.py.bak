from typing import Optional
import asyncio
import logging, datetime, random, time, json, os, hashlib
from aiogram import Bot, Dispatcher, F, Router
router = Router()
from aiogram.exceptions import TelegramBadRequest
from aiogram.filters import CommandStart, Command
from aiogram.types import Message, CallbackQuery, BufferedInputFile, InlineKeyboardMarkup, InlineKeyboardButton
from aiogram.types import FSInputFile

from .config import cfg
from .question_loader import load_catalog, load_bank
from .models import SessionState, Question, Option
from .engine import apply_weights, pick_result, vector_totals
from .mods import compute_mods
from .result_renderer import render_short_card, render_html_report

bank = load_bank()
_sessions = {}
LETTERS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"


async def safe_answer(cb, text: Optional[str] = None):
    """РђРєРєСѓСЂР°С‚РЅРѕ РїРѕРґС‚РІРµСЂР¶РґР°РµС‚ РЅР°Р¶Р°С‚РёРµ РёРЅР»Р°Р№РЅ-РєРЅРѕРїРєРё.
    Р“Р°СЃРёС‚ TelegramBadRequest: query is too old/invalid id."""
    try:
        if text is None:
            await safe_answer(cb, )
        else:
            await safe_answer(cb, text)
    except TelegramBadRequest:
        pass


def find_q(qid: str) -> Optional[Question]:
    for q in bank.questions:
        if q.id == qid:
            return q
    return None

def st_for(chat_id: int) -> SessionState:
    st = _sessions.get(chat_id)
    if not st:
        st = SessionState(chat_id=chat_id)
        _sessions[chat_id] = st
    return st

# РўРµРєСЃС‚С‹/Р»РµР№Р±Р»С‹ РїРѕ СЂРµР¶РёРјСѓ
def q_text(q: Question, mode: str) -> str:
    if mode == "child" and q.text_child:
        return q.text_child
    if mode == "teen" and q.text_teen:
        return q.text_teen
    return q.text or q.text_child or q.text_teen or "Р’РѕРїСЂРѕСЃ"

def q_intro(q: Question, mode: str) -> str:
    # РѕР±С‰РёР№ intro (РґР»СЏ РІР·СЂРѕСЃР»С‹С…) Рё СЃРїРµС†. РїРѕ Р°СѓРґРёС‚РѕСЂРёРё
    if getattr(q, "intro", None):
        return q.intro or ""
    if mode == "child" and q.intro_child:
        return q.intro_child
    if mode == "teen" and q.intro_teen:
        return q.intro_teen
    return ""

def opt_label(o: Option, mode: str) -> str:
    if mode == "child" and o.label_child:
        return o.label_child
    if mode == "teen" and o.label_teen:
        return o.label_teen
    return o.label or o.label_child or o.label_teen or "Р’Р°СЂРёР°РЅС‚"

def enum_opts(q: Question):
    return [(LETTERS[i], o) for i, o in enumerate(q.options)]

# РљР»Р°РІРёР°С‚СѓСЂС‹
def kb_single(q: Question) -> InlineKeyboardMarkup:
    rows, row = [], []
    for i, (letter, o) in enumerate(enum_opts(q), 1):
        row.append(InlineKeyboardButton(text=letter, callback_data=f"ans:{q.id}:{o.id}"))
        if i % 2 == 0:
            rows.append(row); row = []
    if row: rows.append(row)
    return InlineKeyboardMarkup(inline_keyboard=rows)

def kb_rank(q: Question, phase: str) -> InlineKeyboardMarkup:
    rows, row = [], []
    for i, (letter, o) in enumerate(enum_opts(q), 1):
        row.append(InlineKeyboardButton(text=letter, callback_data=f"{phase}:{q.id}:{o.id}"))
        if i % 2 == 0:
            rows.append(row); row = []
    if row: rows.append(row)
    return InlineKeyboardMarkup(inline_keyboard=rows)

# Р¤РёР»СЊС‚СЂ РІРѕРїСЂРѕСЃРѕРІ РїРѕ Р°СѓРґРёС‚РѕСЂРёРё Рё СЃС‚РёР»СЋ
def _match_tags(q: Question, mode: str, style: str) -> bool:
    tags = set(getattr(q, "tags", []) or [])
    return (f"aud:{mode}" in tags) and (f"style:{style}" in tags)

# РџРѕСЃС‚СЂРѕРµРЅРёРµ РјР°СЂС€СЂСѓС‚Р°
def _rand(seed_str: str):
    rnd = random.Random()
    h = int(hashlib.sha256(seed_str.encode("utf-8")).hexdigest(), 16)
    rnd.seed(h)
    return rnd

def build_route(sample_size: int, chat_id: int, mode: str, style: str) -> list:
    # Р±РµСЂС‘Рј С‚РѕР»СЊРєРѕ single Рё С‚РѕР»СЊРєРѕ РїРѕ СЃС‚РёР»СЋ/Р°СѓРґРёС‚РѕСЂРёРё
    singles = [q.id for q in bank.questions if q.format=='single' and _match_tags(q, mode, style)]
    rnd = _rand(f"{chat_id}-{datetime.date.today().isoformat()}")
    rnd.shuffle(singles)
    return singles[:min(sample_size, len(singles))]




def build_route_prefer_rich(sample_size: int, chat_id: int, mode: str, style: str) -> list:
    # 1) СЃРѕР±РёСЂР°РµРј РїРѕ С„РёР»СЊС‚СЂСѓ Р°СѓРґРёС‚РѕСЂРёРё Рё СЃС‚РёР»СЏ
    singles_all = [q for q in bank.questions if q.format == "single" and _match_tags(q, mode, style)]
    bws_all     = [q for q in bank.questions if q.format == "rank_best_worst" and _match_tags(q, mode, style)]

    # 2) РґРµР»РёРј РЅР° rich/РѕР±С‹С‡РЅС‹Рµ
    singles_rich = [q.id for q in singles_all if "quality:rich" in (q.tags or [])]
    singles_norm = [q.id for q in singles_all if "quality:rich" not in (q.tags or [])]
    bws_rich     = [q.id for q in bws_all     if "quality:rich" in (q.tags or [])]
    bws_norm     = [q.id for q in bws_all     if "quality:rich" not in (q.tags or [])]

    # 3) РїРµСЂРµРјРµС€РёРІР°РµРј, СЃС‚Р°РІРёРј rich РїРµСЂРІС‹РјРё
    rnd = _rand(f"{chat_id}-{datetime.date.today().isoformat()}")
    rnd.shuffle(singles_rich); rnd.shuffle(singles_norm)
    rnd.shuffle(bws_rich);     rnd.shuffle(bws_norm)

    singles = (singles_rich + singles_norm)[:min(sample_size, len(singles_rich)+len(singles_norm))]
    bws_ids = (bws_rich + bws_norm)

    # 4) РІСЃС‚Р°РІРєРё best/worst РІ С‚СЂРµС‚СЊСЏС… РјР°СЂС€СЂСѓС‚Р°
    route = []
    if not singles:
        route = bws_ids[:3]
    else:
        cut1 = max(5, len(singles)//3)
        cut2 = max(cut1 + 5, (2*len(singles))//3)
        for i, qid in enumerate(singles, 1):
            route.append(qid)
            if i == cut1 and len(bws_ids) >= 1: route.append(bws_ids[0])
            if i == cut2 and len(bws_ids) >= 2: route.append(bws_ids[1])
        if len(bws_ids) >= 3: route.append(bws_ids[2])
    return route

# РґРµР»Р°РµРј РµС‘ РѕСЃРЅРѕРІРЅРѕР№
build_route = build_route_prefer_rich



async def safe_answer(cb, text: Optional[str] = None):
    """РђРєРєСѓСЂР°С‚РЅРѕ РїРѕРґС‚РІРµСЂР¶РґР°РµС‚ РЅР°Р¶Р°С‚РёРµ РёРЅР»Р°Р№РЅ-РєРЅРѕРїРєРё.
    Р“Р°СЃРёС‚ TelegramBadRequest: query is too old/invalid id."""
    try:
        if text is None:
            await cb.answer()
        else:
            await cb.answer(text)
    except TelegramBadRequest:
        pass

def next_in_route(st: SessionState) -> Optional[str]:
    asked = set(st.asked)
    for qid in st.route_core:
        if qid not in asked:
            return qid
    return None

async def send_q(m: Message, st: SessionState, qid: str):
    q = find_q(qid)
    if not q:
        await m.answer("Р’РѕРїСЂРѕСЃ РЅРµ РЅР°Р№РґРµРЅ"); return
    st.asked.append(qid)
    st.answers.setdefault(qid, {})
    st.answers[qid]["_asked_ts"] = time.time()

    lines = [f"*{q_text(q, st.mode)}*", ""]
    intr = q_intro(q, st.mode).strip()
    if intr: lines += [f"_{intr}_", ""]
    for letter, o in enum_opts(q):
        lines.append(f"{letter}) {opt_label(o, st.mode)}")
    text = "\n".join(lines)

    if q.format == "single":
        await m.answer(text, reply_markup=kb_single(q), parse_mode="Markdown")
    else:
        text += "\n\nР’С‹Р±РµСЂРё: С‡С‚Рѕ *Р±Р»РёР¶Рµ РІСЃРµРіРѕ С‚РµР±Рµ*"
        await m.answer(text, reply_markup=kb_rank(q, "best"), parse_mode="Markdown")
async def finish_and_report(m, st):
    """Финиш опроса: считаем результат, готовим HTML, шлём одним файлом."""
    # Короткая карточка (если есть рендерер)
    try:
        vectors = vector_totals(st)
    except Exception:
        vectors = {}
    try:
        code = pick_result(vectors)
    except Exception:
        code = "—"
    try:
        short = render_short_card(code)
        await m.answer(short)
    except Exception:
        # тихо: карточка не критична
        pass

    # Модификаторы (если получится): берём актуальный каталог
    mods = {"raw": {}, "pairs": []}
    try:
        catalog = load_catalog(getattr(st, "mode", "teen"), getattr(st, "style", "classic"))
        try:
            mods = compute_mods(getattr(st, "answers", {}) or {}, catalog) or mods
        except Exception:
            pass
    except Exception:
        pass

    # Сформируем HTML отчёт (поддержим разные сигнатуры)
    html = "<h1>Отчёт</h1>"
    try:
        html = render_html_report(code, vectors, getattr(st, "answers", {}) or {}, [], mods)
    except TypeError:
        try:
            html = render_html_report(code, vectors, getattr(st, "answers", {}) or {}, [])
        except TypeError:
            try:
                html = render_html_report(code, vectors)
            except Exception:
                pass
    except Exception:
        pass

    # Сохраняем и шлём одним документом
    try:
        import time, pathlib
        reports_dir = pathlib.Path("data/reports"); reports_dir.mkdir(parents=True, exist_ok=True)
        fname = f"report_{m.chat.id}_{int(time.time())}.html"
        fpath = reports_dir / fname
        fpath.write_text(html, encoding="utf-8")
        await m.answer_document(FSInputFile(fpath, filename=fname), caption="Полная версия отчёта (HTML)")
    except Exception:
        # на крайний случай
        try:
            await m.answer(html[:3500])
        except Exception:
            await m.answer("Готово! (не удалось отправить файл отчёта)")

async def after(m: Message, st: SessionState):
    qid = next_in_route(st)
    if qid is None:
        await finish_and_report(m, st); return
    await send_q(m, st, qid)

# РњРµРЅСЋ
