    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Р”РµС‚Рё", callback_data="aud:child")],
        [InlineKeyboardButton(text="РџРѕРґСЂРѕСЃС‚РєРё", callback_data="aud:teen")],
        [InlineKeyboardButton(text="Р’Р·СЂРѕСЃР»С‹Рµ", callback_data="aud:adult")],
    ])

def kb_gender() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="РњСѓР¶СЃРєРѕР№", callback_data="gender:male")],
        [InlineKeyboardButton(text="Р–РµРЅСЃРєРёР№", callback_data="gender:female")],
        [InlineKeyboardButton(text="РќРµ СѓРєР°Р·С‹РІР°С‚СЊ", callback_data="gender:skip")],
    ])

def kb_length() -> InlineKeyboardMarkup:
    return InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Р­РєСЃРїСЂРµСЃСЃ", callback_data="len:express")],
        [InlineKeyboardButton(text="РЎС‚Р°РЅРґР°СЂС‚", callback_data="len:standard")],
        [InlineKeyboardButton(text="Р“Р»СѓР±РѕРєРёР№", callback_data="len:deep")],
    ])

async def intro_text(m: Message):
    txt = (
        "РџСЂР°РІРёР»СЊРЅС‹С… РѕС‚РІРµС‚РѕРІ РЅРµС‚ вЂ” РІС‹Р±РёСЂР°Р№ С‚Рѕ, С‡С‚Рѕ Р±Р»РёР¶Рµ С‚РµР±Рµ. РЈ С‚РµР±СЏ РІСЃС‘ РїРѕР»СѓС‡РёС‚СЃСЏ!"
    )
    await m.answer(txt, parse_mode="Markdown", reply_markup=kb_audience())

def length_hint() -> str:
    return (
        "Р’С‹Р±РµСЂРё РѕР±СЉС‘Рј С‚РµСЃС‚Р°:\n\n"
        "вЂў Р­РєСЃРїСЂРµСЃСЃ вЂ” РѕРєРѕР»Рѕ 24 РІРѕРїСЂРѕСЃРѕРІ (в‰€10вЂ“12 РјРёРЅСѓС‚)\n"
        "вЂў РЎС‚Р°РЅРґР°СЂС‚ вЂ” РѕРєРѕР»Рѕ 48 РІРѕРїСЂРѕСЃРѕРІ (в‰€20вЂ“25 РјРёРЅСѓС‚)\n"
        "вЂў Р“Р»СѓР±РѕРєРёР№ вЂ” РѕРєРѕР»Рѕ 72 РІРѕРїСЂРѕСЃРѕРІ (в‰€35вЂ“45 РјРёРЅСѓС‚)"
    )

async def main():
    from .config import cfg
    logging.basicConfig(level=logging.INFO, format='[%(levelname)s] %(name)s: %(message)s')
    bot = Bot(cfg.BOT_TOKEN)
    # РЅР° РІСЃСЏРєРёР№ вЂ” РІС‹РєР»СЋС‡РёРј РІРµР±С…СѓРє, С‡С‚РѕР±С‹ РІРєР»СЋС‡РёР»СЃСЏ long polling
    try:
        await bot.delete_webhook(drop_pending_updates=True)
    except Exception as e:
        logging.warning(f"delete_webhook failed: {e}")
    dp = Dispatcher()
    dp.include_router(router)
    print("Bot is starting... (polling)")
    # СЂР°Р·СЂРµС€С‘РЅРЅС‹Рµ С‚РёРїС‹ Р°РїРґРµР№С‚РѕРІ РёР· Р·Р°СЂРµРіРёСЃС‚СЂРёСЂРѕРІР°РЅРЅС‹С… С…СЌРЅРґР»РµСЂРѕРІ
    allowed = dp.resolve_used_update_types()
    await dp.start_polling(bot, allowed_updates=allowed)

    def _plan_and_start(m: Message, st: SessionState) -> str:
        samples = {"express": 24, "standard": 48, "deep": 72}
        sample_n = samples.get(st.length, 48)
        st.route_core = build_route(sample_n, m.chat.id, st.mode, st.style)
        return "РќР°С‡РёРЅР°РµРј!"

@router.message(CommandStart())
async def start(m: Message):
        st = SessionState(chat_id=m.chat.id, started_at=datetime.datetime.utcnow().isoformat()+"Z")
        _sessions[m.chat.id]=st
        await intro_text(m)

@router.message(Command("reset"))
async def reset(m: Message):
        st = SessionState(chat_id=m.chat.id, started_at=datetime.datetime.utcnow().isoformat()+"Z")
        _sessions[m.chat.id]=st
        await m.answer("Начали заново.")
        await intro_text(m)
def kb_format():
    from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton as B
    return InlineKeyboardMarkup(inline_keyboard=[
        [B(text="Классика", callback_data="fmt:classic")],
        [B(text="Истории",  callback_data="fmt:story")],
    ])

async def ask_format(m, st):
    txt = (
        "Выбери формат вопросов:\n\n"
        "• Классика — короткие, чёткие ситуации.\n"
        "• Истории — развернутые мини-сюжеты с погружением."
    )
    await m.answer(txt, reply_markup=kb_format())

@router.callback_query(F.data.startswith("fmt:"))
async def set_format(cb: CallbackQuery):
    _, val = cb.data.split(":", 1)
    st = st_for(cb.message.chat.id)
    st.style = val if val in ("classic","story") else "classic"
    await safe_answer(cb, "Ок")
    await cb.message.answer(length_hint(), reply_markup=kb_length())

@router.callback_query(F.data.startswith("aud:"))
async def set_aud(cb: CallbackQuery):
    _, val = cb.data.split(":", 1)
    st = st_for(cb.message.chat.id)
    st.mode = val if val in ("child","teen","adult") else "teen"
    await safe_answer(cb, "Ок")
    await cb.message.answer("Укажи пол.", reply_markup=kb_gender())


@router.callback_query(F.data.startswith("gender:"))
async def set_gender(cb: CallbackQuery):
        _, val = cb.data.split(":",1)
        st = st_for(cb.message.chat.id)
        st.gender = val if val in ("male","female","skip") else "skip"
        await safe_answer(cb, "Сохранено")
        await ask_format(cb.message, st)

@router.callback_query(F.data.startswith("len:"))
async def set_length(cb: CallbackQuery):
    _, val = cb.data.split(":", 1)
    st = st_for(cb.message.chat.id)
    st.length = val if val in ("express","standard","deep") else "standard"
    await safe_answer(cb, "Объём выбран")
    print(f"[DEBUG] set_length: length={st.length} mode={getattr(st,'mode',None)} style={getattr(st,'style',None)}")
    intro = _plan_and_start(cb, st)
    if not getattr(st, "route_core", None):
        await cb.message.answer("Пока не нашлось вопросов для выбранных настроек. Попробуй другой формат/объём.")
        return
    print(f"[DEBUG] route size: {len(st.route_core)}")
    await cb.message.answer("Начинаем!")
    await cb.message.answer(intro)
    await send_q(cb.message, st, st.route_core[0])

@router.callback_query(F.data.startswith("len:"))
def _plan_and_start(m, st=None):
    """РџР»Р°РЅРёСЂСѓРµС‚ РјР°СЂС€СЂСѓС‚ РїРѕ РІС‹Р±СЂР°РЅРЅРѕРјСѓ РѕР±СЉС‘РјСѓ Рё СЂРµР¶РёРјР°Рј.
    m вЂ” Message РР›Р CallbackQuery; st вЂ” SessionState РёР»Рё None."""
    # Р”РѕСЃС‚Р°С‘Рј Message Рё chat_id РёР· Message Р»РёР±Рѕ РёР· CallbackQuery
    msg = getattr(m, 'message', m)
    chat = getattr(msg, 'chat', None)
    chat_id = getattr(chat, 'id', None)
    if st is None:
        if chat_id is None:
            raise RuntimeError('РќРµС‚ chat_id РґР»СЏ РІС‹Р±РѕСЂР° СЃРµСЃСЃРёРё')
        st = st_for(chat_id)
    # РћР±СЉС‘Рј в†’ РєРѕР»РёС‡РµСЃС‚РІРѕ РІРѕРїСЂРѕСЃРѕРІ
    length = getattr(st, 'length', 'standard') or 'standard'
    sample_map = {'express': 12, 'standard': 24, 'deep': 40}
    sample_n = sample_map.get(length, 24)
    # Р РµР¶РёРјС‹ РїРѕ СѓРјРѕР»С‡Р°РЅРёСЋ
    st.mode = getattr(st, 'mode', 'teen') or 'teen'
    st.style = getattr(st, 'style', 'classic') or 'classic'
    # РџР»Р°РЅРёСЂСѓРµРј РјР°СЂС€СЂСѓС‚
    if chat_id is None:
        chat_id = msg.chat.id
    st.route_core = build_route(sample_n, chat_id, st.mode, st.style)
        # РµСЃР»Рё РїРѕ РІС‹Р±СЂР°РЅРЅС‹Рј РїР°СЂР°РјРµС‚СЂР°Рј РјР°СЂС€СЂСѓС‚ РїСѓСЃС‚ вЂ” РїРѕРїСЂРѕР±СѓРµРј Р°Р»СЊС‚РµСЂРЅР°С‚РёРІРЅС‹Р№ С„РѕСЂРјР°С‚
    if not getattr(st, 'route_core', None):
        alt = 'classic' if st.style == 'story' else 'story'
        try:
            st.route_core = build_route(sample_n, chat_id, st.mode, alt)
            st.style = alt if st.route_core else st.style
        except Exception:
            pass

    return 'РќР°С‡РёРЅР°РµРј!'



async def set_length(cb: CallbackQuery):
        _, val = cb.data.split(":",1)
        st = st_for(cb.message.chat.id)
        st.length = val if val in ("express","standard","deep") else "standard"
        await safe_answer(cb, "Объём выбран")
        intro = _plan_and_start(cb.message, st)
        await cb.message.answer(intro)
        await send_q(cb.message, st, st.route_core[0])

@router.callback_query(F.data.startswith("ans:"))
async def ans(cb: CallbackQuery):
        _, qid, opt_id = cb.data.split(":",2)
        st = st_for(cb.message.chat.id); q = find_q(qid)
        opt = next((o for o in q.options if o.id==opt_id), None)
        apply_weights(st, opt.weights, 1.0)
        asked = st.answers.get(qid,{}).get("_asked_ts")
        if asked: st.answers[qid]["single_ms"] = int((time.time()-asked)*1000)
        await safe_answer(cb, f"Выбрано: {opt_label(opt, st.mode)}")
        await after(cb.message, st)



