# src/mods.py — вычисление модификаторов
from typing import Dict

def compute_mods(answers: Dict[str,str], bank) -> Dict[str,float]:
    """
    answers: {question_id: option_id}
    bank: объект с bank.questions, где у options может быть field 'mods': {"E":1, "O":1, "C":1, "P":1, "B":1, "Pap":1}
    Возвращаем суммарные счёты по осям.
    """
    mods={}
    by_id={q.id:q for q in getattr(bank,"questions",[])}
    for qid, oid in (answers or {}).items():
        q=by_id.get(qid); 
        if not q: continue
        opt=None
        for o in getattr(q,"options",[]) or []:
            if o.get("id")==oid: opt=o; break
        if not opt: continue
        for k,v in (opt.get("mods") or {}).items():
            mods[k]=mods.get(k,0.0)+float(v)
    return mods
